# Copy this file to scripts/sign.env (which is gitignored) and fill in your
# signing identity. Run `security find-identity -v -p codesigning` to list the
# identities installed on your machine.
#
# Signing with a stable identity makes macOS (TCC) remember the Accessibility &
# Microphone grants across rebuilds. Without it, `tauri build` ad-hoc signs, the
# cdhash changes every build, and macOS re-prompts for permissions each time.
export APPLE_SIGNING_IDENTITY="Apple Development: Your Name (TEAMID)"

# --- Notarized RELEASE builds only (distribution to other Macs) ---
# Requires a "Developer ID Application" cert (paid Apple Developer Program) in
# APPLE_SIGNING_IDENTITY above. Set all three vars below and `tauri build` will
# sign AND notarize; leave them unset to only sign locally (fast, no notarize).
# export APPLE_ID="you@example.com"
# export APPLE_PASSWORD="xxxx-xxxx-xxxx-xxxx"   # app-specific password
# export APPLE_TEAM_ID="TEAMID"
