{
  "name": "whisp-line",
  "version": "1.0.85",
  "description": "Voice input method software built with Tauri",
  "main": "src/main.js",
  "scripts": {
    "start": "tauri dev",
    "dev": "tauri dev",
    "version:tauri:patch": "node scripts/bump-tauri-version.js",
    "build": "npm run version:tauri:patch && tauri build",
    "build:mac": "npm run version:tauri:patch && tauri build --target aarch64-apple-darwin",
    "build:win": "npm run version:tauri:patch && tauri build --target x86_64-pc-windows-msvc",
    "build:linux": "npm run version:tauri:patch && tauri build --target x86_64-unknown-linux-gnu",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "npm run version:tauri:patch && tauri build",
    "tauri:build:mac": "npm run version:tauri:patch && tauri build --target aarch64-apple-darwin",
    "electron:start": "electron .",
    "electron:dev": "electron . --dev",
    "electron:build": "npm version patch --no-git-tag-version && electron-builder",
    "electron:build:mac": "npm version patch --no-git-tag-version && electron-builder --mac",
    "electron:build:win": "npm version patch --no-git-tag-version && electron-builder --win",
    "electron:build:linux": "npm version patch --no-git-tag-version && electron-builder --linux",
    "icon:mac": "bash -c 'ICON=assets/icon.png; OUT=assets/icon.icns; TMP=assets/app.iconset; rm -rf \"$TMP\" \"$OUT\"; mkdir \"$TMP\"; for SIZE in 16 32 64 128 256 512; do sips -z $SIZE $SIZE \"$ICON\" --out \"$TMP/icon_${SIZE}x${SIZE}.png\" >/dev/null; sips -z $((SIZE*2)) $((SIZE*2)) \"$ICON\" --out \"$TMP/icon_${SIZE}x${SIZE}@2x.png\" >/dev/null; done; iconutil -c icns \"$TMP\" -o \"$OUT\"; rm -rf \"$TMP\"'",
    "icon:win": "node -e \"require('png-to-ico')('assets/icon.png').then(buf=>require('fs').writeFileSync('assets/icon.ico',buf)).catch(e=>{console.error(e);process.exit(1);})\""
  },
  "keywords": [
    "electron",
    "voice",
    "input",
    "transcription"
  ],
  "author": "Tao",
  "license": "PolyForm-Noncommercial-1.0.0",
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "electron": "^37.2.6",
    "electron-builder": "^26.0.12",
    "png-to-ico": "^2.1.8"
  },
  "dependencies": {
    "auto-launch": "^5.0.6",
    "electron-store": "^10.1.0",
    "groq-sdk": "^0.30.0",
    "koffi": "^2.13.0",
    "openai": "^4.57.0",
    "uiohook-napi": "^1.5.4"
  },
  "build": {
    "appId": "com.tao.whispline",
    "productName": "WhispLine",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*"
    ],
    "mac": {
      "icon": "assets/icon.icns",
      "category": "public.app-category.productivity",
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "files": [
        "!node_modules/koffi/**/*"
      ],
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "extendInfo": {
        "CFBundleDisplayName": "WhispLine",
        "CFBundleName": "WhispLine",
        "CFBundleIdentifier": "com.tao.whispline",
        "NSMicrophoneUsageDescription": "WhispLine needs microphone access to transcribe your voice input.",
        "NSAppleEventsUsageDescription": "WhispLine needs Apple Events access to insert text into other applications.",
        "LSMinimumSystemVersion": "10.15.0"
      }
    },
    "dmg": {
      "title": "Install WhispLine",
      "backgroundColor": "#f5f7fa",
      "iconSize": 120,
      "window": {
        "width": 680,
        "height": 440
      },
      "contents": [
        {
          "x": 210,
          "y": 170,
          "type": "file"
        },
        {
          "x": 470,
          "y": 170,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": "nsis",
      "asarUnpack": [
        "node_modules/koffi/**"
      ]
    },
    "linux": {
      "target": "AppImage",
      "asarUnpack": [
        "node_modules/koffi/**"
      ]
    }
  }
}
